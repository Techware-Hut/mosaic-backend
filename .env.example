# Core runtime

PORT=3001

NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/mbh

FRONTEND_URL=http://localhost:3000

JWT_SECRET=replace-with-a-long-random-secret

COOKIE_DOMAIN=

COOKIE_SECURE=false

COOKIE_SAMESITE=lax



# Google OAuth (required at boot — authController throws if missing)

GOOGLE_CLIENT_ID=replace-me

GOOGLE_CLIENT_SECRET=replace-me

API_BASE_URL=http://localhost:3001



# Stripe — use names that match code/README (not legacy STRIPE_WEBHOOK_SECRET names)

STRIPE_SECRET_KEY=sk_test_replace_me

STRIPE_ORDER_WEBHOOK_SECRET=whsec_replace_order_status_webhook

STRIPE_BUSINESS_DRAFT_WEBHOOK_SECRET=whsec_replace_business_draft_webhook

STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_replace_subscription_webhook

STRIPE_VENDOR_VERIFICATION_WEBHOOK_SECRET=whsec_replace_vendor_verification_webhook

STRIPE_ORDER_POST_PAYMENT_WEBHOOK_SECRET=whsec_replace_order_email_webhook

PLATFORM_FEE_CENTS=100

BILLING_PORTAL_RETURN_URL=http://localhost:3000/billing

CONNECT_RETURN_PATH=/partners/connect/return

CONNECT_REFRESH_PATH=/partners/connect/refresh

CONNECT_RETURN_URL=http://localhost:3000/partners/connect/return

CONNECT_REFRESH_URL=http://localhost:3000/partners/connect/refresh



# AWS S3

AWS_REGION=us-east-1

AWS_ACCESS_KEY_ID=replace-me

AWS_SECRET_ACCESS_KEY=replace-me

AWS_S3_BUCKET=replace-me



# Email and notifications

MAIL_USER=you@example.com

MAIL_PASSWORD=replace-me

ADMIN_EMAIL=admin@example.com

SUPPORT_EMAIL=support@example.com

APP_NAME=Mosaic Biz Hub

APP_URL=http://localhost:3000



# Optional storage/provider settings

# Optional observability (production: set on EB only)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=mosaic-local

STORAGE_PROVIDER=aws

CLOUDINARY_CLOUD_NAME=replace-me-if-used

CLOUDINARY_API_KEY=replace-me-if-used

CLOUDINARY_API_SECRET=replace-me-if-used



# Google (optional beyond OAuth boot requirements)

GOOGLE_GEOCODING_API_KEY=replace-me-if-used



# PayPal

PAYPAL_CLIENT_ID=replace-me-if-used

PAYPAL_CLIENT_SECRET=replace-me-if-used



# PDF / browser

PUPPETEER_EXECUTABLE_PATH=



# Debug

LISTING_DEBUG=false

